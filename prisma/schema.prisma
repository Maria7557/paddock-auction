generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  role      Role     @default(USER)
  wallet    Wallet?
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Wallet {
  id            String         @id @default(uuid())
  userId        String         @unique
  balance       Int            @default(0)
  lockedBalance Int            @default(0)
  createdAt     DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id])
  ledger        WalletLedger[]
  depositLocks  DepositLock[]
}

model WalletLedger {
  id        String     @id @default(uuid())
  walletId  String
  type      LedgerType
  amount    Int
  reference String?
  createdAt DateTime   @default(now())
  wallet    Wallet     @relation(fields: [walletId], references: [id])

  @@index([walletId], map: "walletledger_wallet_idx")
}

model DepositLock {
  id               String            @id @default(uuid())
  walletId         String            @map("wallet_id")
  auctionId        String            @map("auction_id")
  amount           Int
  status           DepositLockStatus @default(ACTIVE)
  createdAt        DateTime          @default(now()) @map("created_at")
  releasedAt       DateTime?         @map("released_at")
  burnedAt         DateTime?         @map("burned_at")
  resolutionReason String?           @map("resolution_reason")
  wallet           Wallet            @relation(fields: [walletId], references: [id])

  @@map("deposit_locks")
  @@index([walletId], map: "depositlock_wallet_idx")
}

enum LedgerType {
  DEPOSIT_TOPUP
  DEPOSIT_LOCK
  DEPOSIT_RELEASE
  DEPOSIT_BURN
  PAYMENT_RECEIVED
  WITHDRAWAL
}

enum DepositLockStatus {
  ACTIVE
  RELEASED
  BURNED
}
