generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  role         UserRole      @default(BUYER)
  status       UserStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now())
  wallet       Wallet?
  companyUsers CompanyUser[]
}

model Wallet {
  id            String         @id @default(uuid())
  userId        String         @unique
  balance       Decimal        @default(0) @db.Decimal(18, 2)
  lockedBalance Decimal        @default(0) @db.Decimal(18, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger        WalletLedger[]
  depositLocks  DepositLock[]
}

model WalletLedger {
  id        String     @id @default(uuid())
  walletId  String
  type      LedgerType
  amount    Int
  reference String?
  createdAt DateTime   @default(now())
  wallet    Wallet     @relation(fields: [walletId], references: [id])

  @@index([walletId], map: "walletledger_wallet_idx")
}

model DepositLock {
  id               String            @id @default(uuid())
  walletId         String            @map("wallet_id")
  auctionId        String            @map("auction_id")
  amount           Int
  status           DepositLockStatus @default(ACTIVE)
  createdAt        DateTime          @default(now()) @map("created_at")
  releasedAt       DateTime?         @map("released_at")
  burnedAt         DateTime?         @map("burned_at")
  resolutionReason String?           @map("resolution_reason")
  wallet           Wallet            @relation(fields: [walletId], references: [id])

  @@map("deposit_locks")
  @@index([walletId], map: "depositlock_wallet_idx")
}

model Company {
  id                 String        @id @default(uuid())
  name               String
  country            String
  registrationNumber String        @unique
  status             CompanyStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  users              CompanyUser[]
}

model CompanyUser {
  id        String          @id @default(uuid())
  userId    String
  companyId String
  role      CompanyUserRole
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model Vehicle {
  id      String @id @default(uuid())
  brand   String
  model   String
  year    Int
  mileage Int
  vin     String @unique
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CompanyUserRole {
  OWNER
  MANAGER
  MEMBER
}

enum LedgerType {
  DEPOSIT_TOPUP
  DEPOSIT_LOCK
  DEPOSIT_RELEASE
  DEPOSIT_BURN
  PAYMENT_RECEIVED
  WITHDRAWAL
}

enum DepositLockStatus {
  ACTIVE
  RELEASED
  BURNED
}
