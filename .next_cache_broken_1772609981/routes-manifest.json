{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/payments/invoices/[invoiceId]/intent",
      "regex": "^/api/payments/invoices/([^/]+?)/intent(?:/)?$",
      "routeKeys": {
        "nxtPinvoiceId": "nxtPinvoiceId"
      },
      "namedRegex": "^/api/payments/invoices/(?<nxtPinvoiceId>[^/]+?)/intent(?:/)?$"
    },
    {
      "page": "/api/ui/auctions/[auctionId]",
      "regex": "^/api/ui/auctions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPauctionId": "nxtPauctionId"
      },
      "namedRegex": "^/api/ui/auctions/(?<nxtPauctionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/ui/auctions/[auctionId]/bids",
      "regex": "^/api/ui/auctions/([^/]+?)/bids(?:/)?$",
      "routeKeys": {
        "nxtPauctionId": "nxtPauctionId"
      },
      "namedRegex": "^/api/ui/auctions/(?<nxtPauctionId>[^/]+?)/bids(?:/)?$"
    },
    {
      "page": "/auctions/[auctionId]",
